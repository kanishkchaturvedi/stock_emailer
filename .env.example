# Smart Money Tracker Configuration

# OpenAI Configuration (REQUIRED)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Finnhub API (optional - for real insider transaction data)
# Sign up free at https://finnhub.io
FINNHUB_API_KEY=your-finnhub-api-key-here

# Email Configuration - Choose one method (SMTP or Resend)
# SMTP Configuration (optional)
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password

# Resend Configuration (optional, alternative to SMTP)
RESEND_API_KEY=re_your-resend-api-key-here

# Report Recipient Email (REQUIRED)
REPORT_EMAIL=recipient@example.com

# Database Configuration
DATABASE_PATH=smart_money.db

# Scoring Configuration
MIN_SCORE_FOR_EMAIL=60
